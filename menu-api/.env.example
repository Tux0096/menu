# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=menu_db

# iiko Cloud API
IIKO_API_LOGIN=your-iiko-api-login

# Ollama (локальная нейросеть на сервере)
OLLAMA_ENABLED=true
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2:0.5b
OLLAMA_TIMEOUT_MS=45000

PORT=3101
