# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=menu_db

# iiko Cloud API
IIKO_API_LOGIN=your-iiko-api-login

# Ollama на том же сервере (внутренний адрес, не для браузера)
OLLAMA_ENABLED=true
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=60000

PORT=3101
