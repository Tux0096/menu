{
  "name": "nuxt-shop-fuji",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt",
    "build": "(rm -rf ./node_modules/.cache/pwa/icon || true) && nuxt build --modern=server && pm2 reload fuji-front",
    "start": "nuxt start --modern=server",
    "build:modern": "nuxt build --modern=server",
    "start:modern": "nuxt start --modern=server",
    "generate": "nuxt generate",
    "gen-cap": "nuxt generate && npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "generate:icon": "npx @capacitor/assets generate --iconBackgroundColor '#eeeeee' --iconBackgroundColorDark '#222222' --splashBackgroundColor '#eeeeee' --splashBackgroundColorDark '#111111' --assetPath ./resources",
    "stats": "nuxt build -a",
    "lint": "npm run lint:js",
    "lintfix": "eslint --fix --ext .js,.vue --ignore-path .gitignore .",
    "lint:js": "eslint --ext .js,.vue --ignore-path .gitignore ."
  },
  "dependencies": {
    "@capacitor/android": "5.6.0",
    "@capacitor/app": "5.0.6",
    "@capacitor/cli": "5.6.0",
    "@capacitor/core": "5.6.0",
    "@capacitor/geolocation": "5.0.6",
    "@capacitor/ios": "5.6.0",
    "@capacitor/keyboard": "5.0.8",
    "@capacitor/push-notifications": "5.1.0",
    "@capawesome/capacitor-app-update": "5.1.0",
    "@nuxt/image": "0.7.1",
    "@nuxt/types": "2.17.0",
    "@nuxt/typescript-build": "3.0.1",
    "@nuxtjs/axios": "5.13.6",
    "@nuxtjs/date-fns": "1.5.0",
    "@nuxtjs/device": "2.1.0",
    "@nuxtjs/dotenv": "1.4.1",
    "@nuxtjs/google-analytics": "2.4.0",
    "@nuxtjs/pwa": "3.3.5",
    "@nuxtjs/recaptcha": "1.1.2",
    "@nuxtjs/robots": "2.5.0",
    "@nuxtjs/sentry": "8.0.1",
    "@nuxtjs/sitemap": "2.4.0",
    "@nuxtjs/style-resources": "1.2.1",
    "@nuxtjs/svg": "0.3.0",
    "@nuxtjs/svg-sprite": "1.0.0-beta.2",
    "@rkaliev/nuxtjs-yandex-metrika": "1.3.0",
    "@types/yandex-maps": "2.1.30",
    "axios": "0.27.2",
    "capacitor-plugin-safe-area": "2.0.5",
    "connect": "3.7.0",
    "cookie-universal-nuxt": "2.2.1",
    "core-js": "3.23.4",
    "dotenv": "16.3.1",
    "firebase": "10.12.3",
    "gsap": "3.12.5",
    "ipx": "0.9.10",
    "libphonenumber-js": "1.10.7",
    "lord-icon-element": "4.0.3",
    "nuxt": "2.17.0",
    "nuxt-client-init-module": "0.3.0",
    "nuxt-compress": "5.0.0",
    "nuxt-delay-hydration": "0.4.7",
    "nuxt-ssr-cache": "1.5.2",
    "nuxt-start": "2.15.8",
    "portal-vue": "2.1.7",
    "sass": "1.53.0",
    "sass-loader": "10.3.1",
    "swiper": "5.4.5",
    "v-mask": "2.3.0",
    "vue": "2.7.14",
    "vue-awesome-swiper": "4.1.1",
    "vue-multiselect": "2.1.7",
    "vue-notification": "1.3.20",
    "vue2-touch-events": "3.2.2",
    "vuex": "3.6.2",
    "vuex-persist": "3.1.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "7.21.11",
    "@capacitor/assets": "2.0.4",
    "@nuxtjs/eslint-config-typescript": "12.0.0",
    "@typescript-eslint/eslint-plugin": "5.59.0",
    "@typescript-eslint/parser": "5.59.0",
    "eslint": "8.38.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-airbnb-typescript": "17.0.0",
    "eslint-import-resolver-nuxt": "1.0.1",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-nuxt": "3.2.0",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-vue": "9.2.0",
    "typescript": "4.9.5",
    "vue-eslint-parser": "9.1.1"
  }
}
